# ─── Environment: dev | staging | prod ─────────────────────────────────────────
VITE_ENV=development

# ─── Backend API ─────────────────────────────────────────────────────────────────
# Development
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Staging
# VITE_API_BASE_URL=https://api-staging.cqmr.yourdomain.com/api/v1

# Production
# VITE_API_BASE_URL=https://api.cqmr.yourdomain.com/api/v1

# ─── App Config ──────────────────────────────────────────────────────────────────
VITE_APP_NAME=CQMR
VITE_APP_VERSION=1.0.0

# ─── Feature Flags (optional) ────────────────────────────────────────────────────
VITE_ENABLE_DEVTOOLS=true
